# Path-specific rules go ABOVE the catch-all `/*` rule. Cloudflare Pages
# uses first-match semantics: the first block whose path matches gets its
# headers applied, the rest are skipped for that response.

# WebAssembly served with the correct MIME type so the browser will
# actually instantiate it. Without this, Cloudflare's default is
# application/octet-stream and `X-Content-Type-Options: nosniff` below
# stops the browser from guessing — the kernel silently fails to load
# and the /grammar/explore scene never paints.
/_next/static/wasm/*
  Content-Type: application/wasm
  Cache-Control: public, max-age=31536000, immutable

# Catch any other .wasm path (e.g. /coherence-kernel/* if we ever serve
# the kernel directly).
/*.wasm
  Content-Type: application/wasm

/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  X-XSS-Protection: 1; mode=block
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), browsing-topics=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  # CSP adds 'wasm-unsafe-eval' for WebAssembly.instantiate to be allowed.
  # Without it the script-src restricts the V8 wasm pipeline and the
  # kernel module load throws a CSP violation that doesn't bubble to
  # React.
  # worker-src explicitly allows blob: workers. drei's <Text> component
  # (the room labels in the Aleph scene) spawns a Troika SDF font
  # worker from a blob URL; without this it gets blocked and the text
  # silently fails to render (the rest of the scene still works).
  # CSP notes:
  #  - 'wasm-unsafe-eval' gates WebAssembly.instantiate. Required for
  #    the coherence-kernel WASM module.
  #  - 'unsafe-inline' + 'unsafe-eval' are required by Next.js's
  #    runtime and webpack. We could tighten via nonces later.
  #  - blob: and worker-src previously needed for drei <Text>'s Troika
  #    worker pool. <Text> has been removed in favour of drei <Html>
  #    portals (no workers, no external fetches), so we drop blob:
  #    from script-src and connect-src and remove worker-src entirely.
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' 'wasm-unsafe-eval' https://challenges.cloudflare.com https://static.cloudflareinsights.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: https: blob:; connect-src 'self' https://api.brevo.com https://*.ciris.ai https://lens.ciris-services-1.ai https://raw.githubusercontent.com; frame-src 'self' https://www.youtube-nocookie.com https://www.youtube.com; frame-ancestors 'none'; base-uri 'self'; form-action 'self'
