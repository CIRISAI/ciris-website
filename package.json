{
  "name": "newciris",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "NODE_OPTIONS=--max-old-space-size=6144 next build",
    "postbuild": "next-sitemap && node scripts/indexnow.mjs",
    "indexnow": "INDEXNOW_SUBMIT=1 node scripts/indexnow.mjs",
    "dev": "next dev --turbo",
    "start": "next start",
    "postinstall": "fumadocs-mdx",
    "build:safe": "node scripts/safe-build.mjs",
    "build:diag": "(dmesg 2>/dev/null||journalctl -k 2>/dev/null)|grep -iE \"out of memory|oom-kill|killed process\"|tail -20; echo ---; free -h"
  },
  "dependencies": {
    "@phosphor-icons/react": "^2.1.10",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@tabler/icons-react": "^3.34.0",
    "@types/three": "^0.184.1",
    "coherence-kernel": "file:coherence-kernel/pkg",
    "fumadocs-core": "15.2.8",
    "fumadocs-mdx": "11.6.0",
    "fumadocs-ui": "15.2.8",
    "motion": "^12.16.0",
    "motion-plus": "^1.2.0",
    "next": "^15.3.6",
    "react": "^19.1.2",
    "react-dom": "^19.1.2",
    "react-force-graph-2d": "^1.29.1",
    "react-markdown": "^10.1.0",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.4",
    "@types/js-yaml": "^4.0.9",
    "@types/mdx": "^2.0.13",
    "@types/node": "22.14.1",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "js-yaml": "^4.1.1",
    "next-sitemap": "^4.2.3",
    "postcss": "^8.5.3",
    "tailwindcss": "^4.1.4",
    "typescript": "^5.8.3",
    "wrangler": "^4.86.0"
  }
}
